  {
    "domain": "Users",
    "name": "Create User",
    "method": "POST",
    "endpoint": "/api/v1/users",
    "description": "Create a new user. Requires authentication.",
    "request": {
      "headers": [
        { "name": "Authorization", "value": "Bearer {token}", "required": true }
      ],
      "query": [],
      "body": {
        "name": "string (min: 2)",
        "email": "string",
        "password": "string (min: 6)"
      }
    },
    "example_request": {
      "json": {
        "name": "Bob Silva",
        "email": "bob@example.com",
        "password": "bobpass"
      },
      "curl": "curl -X POST {{base_url}}/api/v1/users \\\n  -H 'Authorization: Bearer {token}' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\"name\":\"Bob Silva\",\"email\":\"bob@example.com\",\"password\":\"bobpass\"}'"
    },
    "response": {
      "success": {
        "status": 201,
        "body": {
          "data": {
            "id": 2,
            "name": "Bob Silva",
            "email": "bob@example.com",
            "role": "user",
            "createdAt": "2026-04-07T11:00:00Z",
            "updatedAt": "2026-04-07T11:00:00Z",
            "deletedAt": null
          }
        },
        "fields": [
          { "field": "data.id",        "type": "number",       "description": "Unique user identifier" },
          { "field": "data.name",       "type": "string",       "description": "User's full name" },
          { "field": "data.email",      "type": "string",       "description": "User's email address" },
          { "field": "data.role",       "type": "string",       "description": "User role, defaults to \"user\"" },
          { "field": "data.createdAt",  "type": "string (ISO)", "description": "Account creation timestamp" }
        ]
      }
    },
    "errors": [
      { "code": 401, "message": "Unauthorized",        "description": "Missing or invalid JWT token" },
      { "code": 422, "message": "Validation error",    "description": "Required fields missing or invalid" },
      { "code": 500, "message": "Internal server error","description": "Unexpected error while creating the user" }
    ]
  },
