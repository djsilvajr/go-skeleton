  {
    "domain": "Users",
    "name": "Delete User",
    "method": "DELETE",
    "endpoint": "/api/v1/users/{id}",
    "description": "Soft-delete a user by ID. Requires authentication and admin role.",
    "request": {
      "headers": [
        { "name": "Authorization", "value": "Bearer {token}", "required": true }
      ],
      "query": [],
      "body": null
    },
    "example_request": {
      "json": null,
      "curl": "curl -X DELETE {{base_url}}/api/v1/users/2 \\\n  -H 'Authorization: Bearer {token}'"
    },
    "response": {
      "success": {
        "status": 200,
        "body": {
          "data": {
            "deleted": true
          }
        },
        "fields": [
          { "field": "data.deleted", "type": "boolean", "description": "Always true when the operation succeeds" }
        ]
      }
    },
    "errors": [
      { "code": 400, "message": "Invalid id",           "description": "The provided ID is not a valid integer" },
      { "code": 401, "message": "Unauthorized",         "description": "Missing or invalid JWT token" },
      { "code": 403, "message": "Forbidden",            "description": "Authenticated user does not have the admin role" },
      { "code": 500, "message": "Internal server error","description": "Unexpected error while deleting the user" }
    ]
  }
