[
  {
    "domain": "Users",
    "name": "List Users",
    "method": "GET",
    "endpoint": "/api/v1/users",
    "description": "Return all users. Requires authentication.",
    "request": {
      "headers": [
        { "name": "Authorization", "value": "Bearer {token}", "required": true }
      ],
      "query": [],
      "body": null
    },
    "example_request": {
      "json": null,
      "curl": "curl -X GET {{base_url}}/api/v1/users \\\n  -H 'Authorization: Bearer {token}'"
    },
    "response": {
      "success": {
        "status": 200,
        "body": {
          "data": [
            {
              "id": 1,
              "name": "Alice",
              "email": "alice@example.com",
              "role": "admin",
              "createdAt": "2026-04-07T10:00:00Z",
              "updatedAt": "2026-04-07T10:00:00Z",
              "deletedAt": null
            }
          ]
        },
        "fields": [
          { "field": "data[].id",        "type": "number",       "description": "Unique user identifier" },
          { "field": "data[].name",       "type": "string",       "description": "User's full name" },
          { "field": "data[].email",      "type": "string",       "description": "User's email address" },
          { "field": "data[].role",       "type": "string",       "description": "User role: admin | user" },
          { "field": "data[].createdAt",  "type": "string (ISO)", "description": "Account creation timestamp" },
          { "field": "data[].updatedAt",  "type": "string (ISO)", "description": "Last update timestamp" },
          { "field": "data[].deletedAt",  "type": "string | null","description": "Soft-delete timestamp, null if active" }
        ]
      }
    },
    "errors": [
      { "code": 401, "message": "Unauthorized",           "description": "Missing or invalid JWT token" },
      { "code": 500, "message": "Could not retrieve users", "description": "Internal error while fetching users" }
    ]
  },
