[
  {
    "domain": "Auth",
    "name": "Login",
    "method": "POST",
    "endpoint": "/api/v1/auth/login",
    "description": "Authenticate a user with email and password and return a JWT token.",
    "request": {
      "headers": [],
      "query": [],
      "body": {
        "email": "string",
        "password": "string"
      }
    },
    "example_request": {
      "json": {
        "email": "admin@example.com",
        "password": "secret123"
      },
      "curl": "curl -X POST {{base_url}}/api/v1/auth/login \\\n  -H 'Content-Type: application/json' \\\n  -d '{\"email\":\"admin@example.com\",\"password\":\"secret123\"}'"
    },
    "response": {
      "success": {
        "status": 200,
        "body": {
          "data": {
            "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "type": "Bearer"
          }
        },
        "fields": [
          { "field": "data.token", "type": "string", "description": "JWT access token" },
          { "field": "data.type",  "type": "string", "description": "Token type, always \"Bearer\"" }
        ]
      }
    },
    "errors": [
      { "code": 422, "message": "Validation error",     "description": "Required fields are missing or have invalid format" },
      { "code": 401, "message": "Invalid credentials",  "description": "The email or password does not match any user" },
      { "code": 500, "message": "Could not generate token", "description": "Internal error while signing the JWT" }
    ]
  },
  {
    "domain": "Auth",
    "name": "Register",
    "method": "POST",
    "endpoint": "/api/v1/auth/register",
    "description": "Create a new user account and return a JWT token.",
    "request": {
      "headers": [],
      "query": [],
      "body": {
        "name": "string (min: 2)",
        "email": "string",
        "password": "string (min: 6)"
      }
    },
    "example_request": {
      "json": {
        "name": "Jane Doe",
        "email": "jane@example.com",
        "password": "mypassword"
      },
      "curl": "curl -X POST {{base_url}}/api/v1/auth/register \\\n  -H 'Content-Type: application/json' \\\n  -d '{\"name\":\"Jane Doe\",\"email\":\"jane@example.com\",\"password\":\"mypassword\"}'"
    },
    "response": {
      "success": {
        "status": 201,
        "body": {
          "data": {
            "user": {
              "id": 1,
              "name": "Jane Doe",
              "email": "jane@example.com",
              "role": "user",
              "createdAt": "2026-04-07T10:00:00Z",
              "updatedAt": "2026-04-07T10:00:00Z",
              "deletedAt": null
            },
            "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "type": "Bearer"
          }
        },
        "fields": [
          { "field": "data.user.id",        "type": "number",      "description": "Unique user identifier" },
          { "field": "data.user.name",       "type": "string",      "description": "User's full name" },
          { "field": "data.user.email",      "type": "string",      "description": "User's email address" },
          { "field": "data.user.role",       "type": "string",      "description": "User role: admin | user" },
          { "field": "data.user.createdAt",  "type": "string (ISO)", "description": "Account creation timestamp" },
          { "field": "data.token",           "type": "string",      "description": "JWT access token" },
          { "field": "data.type",            "type": "string",      "description": "Token type, always \"Bearer\"" }
        ]
      }
    },
    "errors": [
      { "code": 422, "message": "Validation error", "description": "Required fields missing, name < 2 chars, or password < 6 chars" },
      { "code": 500, "message": "Internal server error", "description": "Unexpected error while creating the user" }
    ]
  }
]
