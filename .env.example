# Application
APP_NAME=go-skeleton
APP_PORT=8020
APP_ENV=local
APP_DEBUG=true

# Database — aligned with docker-compose defaults
DB_HOST=db
DB_PORT=3306
DB_DATABASE=go_skeleton
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=bananinha123
REDIS_DB=0

# JWT Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOUR=24

# Mail (SMTP — use an app-specific password, not your account password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com

# Observability — set OTEL_ENABLED=true to send traces to Jaeger
OTEL_ENABLED=false
OTEL_SERVICE_NAME=go-skeleton
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
